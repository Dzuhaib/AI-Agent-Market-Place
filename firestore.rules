rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "myselfzuhaib@gmail.com" && request.auth.token.email_verified == true));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Collection: users
    // ===============================================================
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string &&
             (data.role in ['buyer', 'seller', 'both', 'admin']) &&
             (!('onboarded' in data) || data.onboarded is bool) &&
             (!('updatedAt' in data) || data.updatedAt == request.time) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) && isValidUser(incoming()) && (
        // User can update their own profile fields
        incoming().diff(existing()).affectedKeys().hasOnly(['role', 'displayName', 'photoURL', 'onboarded', 'updatedAt', 'createdAt', 'uid', 'email'])
      )) || (isAdmin() && (
        // Admin can update any user's role
        incoming().diff(existing()).affectedKeys().hasOnly(['role', 'updatedAt'])
      ));
    }

    // ===============================================================
    // Collection: agents
    // ===============================================================
    function isValidAgent(data) {
      return data.keys().hasAll(['name', 'description', 'creatorId', 'externalUrl']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.description is string && data.description.size() < 2000 &&
             data.creatorId == request.auth.uid &&
             data.price is number && data.price >= 0 &&
             data.externalUrl is string && data.externalUrl.size() < 500;
    }

    match /agents/{agentId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidAgent(incoming());
      allow update: if (isOwner(existing().creatorId) || isAdmin()) && isValidAgent(incoming());
      allow delete: if isOwner(existing().creatorId) || isAdmin();
    }

    // ===============================================================
    // Collection: purchases
    // Document ID: userId + "_" + agentId
    // ===============================================================
    function isValidPurchase(data) {
      return data.userId == request.auth.uid &&
             data.agentId is string &&
             data.createdAt == request.time;
    }

    match /purchases/{purchaseId} {
      allow read: if isSignedIn() && (isOwner(existing().userId) || isOwner(get(/databases/$(database)/documents/agents/$(existing().agentId)).data.creatorId) || isAdmin());
      // For listing, ensure user only sees their own or their agent's sales
      allow list: if isSignedIn(); 
      allow create: if isSignedIn() && isValidPurchase(incoming());
    }

    // ===============================================================
    // Collection: reviews
    // ===============================================================
    function isValidReview(data) {
      return data.userId == request.auth.uid &&
             data.agentId is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             (!('comment' in data) || (data.comment is string && data.comment.size() < 1000)) &&
             data.createdAt == request.time;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      // Only allow review if user purchased the agent
      // Predicted ID for purchase: userId + "_" + agentId
      allow create: if isSignedIn() && isValidReview(incoming()) && 
                    exists(/databases/$(database)/documents/purchases/$(request.auth.uid + "_" + incoming().agentId));
      allow update, delete: if isOwner(existing().userId) || isAdmin();
    }

    // ===============================================================
    // Collection: runs
    // ===============================================================
    match /runs/{runId} {
      allow read: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
    }
  }
}
